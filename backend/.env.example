# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
LLM_MATCHER_MODEL="gpt-4o-mini"
LLM_TAILOR_MODEL="gpt-4o-mini"

# Gemini free tier — 初筛用 (60 req/min 免费额度)
GEMINI_API_KEY=""
GEMINI_QUICK_SCAN_MODEL="gemini-1.5-flash"

# Embedding 模型 (text-embedding-3-small=1536dim, bge-small=512dim)
EMBED_MODEL="text-embedding-3-small"

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/jobhunt"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── 通知 ──────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── 服务配置 ──────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"
